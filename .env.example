# Google AI Studio の API キー（複数キーでローテーション）
# https://aistudio.google.com/apikey
GOOGLE_API_KEY_1=your_api_key_here
GOOGLE_API_KEY_2=
# ... GOOGLE_API_KEY_10 まで

# 単一キーのみ使う場合（ローテーションなし）
# GEMINI_API_KEY=your_api_key_here

# 使用するキー番号の範囲（省略時は設定済みのキーをすべて使用）
# API_KEY_RANGE=1-10

# 最後に使ったキーのインデックス保存先（省略可）
# API_KEY_SESSION_FILE=.session_data.json
